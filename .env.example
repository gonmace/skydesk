# ── Proyecto ──────────────────────────────────────────────────────────────────
# Nombre del proyecto (usado en contenedores Docker y nginx)
PROJECT_NAME=miproyecto

# ── Dominios ──────────────────────────────────────────────────────────────────
# Dominio principal de Django
DOMAIN=tudominio.com

# ── Puertos (consecutivos desde APP_PORT) ─────────────────────────────────────
# Django se expone en APP_PORT. n8n y MCP usan los siguientes.
APP_PORT=8000
N8N_PORT=8001        # Puerto externo para n8n (solo si N8N_DOMAIN está definido)
N8N_MCP_PORT=8002    # Puerto externo para n8n-MCP (solo si N8N_MCP_ENABLED=true)

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
DEBUG=False
ALLOWED_HOSTS=tudominio.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com
ADMIN_URL=mi-panel-secreto/

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# POSTGRES_MODE: "container" (por defecto) o "host"
#   - container: PostgreSQL corre en Docker (incluido en docker-compose)
#   - host: PostgreSQL ya instalado en el servidor; contenedores se conectan
#           vía host.docker.internal. Requiere configurar pg_hba.conf manualmente.
POSTGRES_MODE=container
POSTGRES_DB=miproyecto_db
POSTGRES_USER=miproyecto_user
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_HOST=postgres              # "postgres" para container, "host.docker.internal" para host
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432             # Puerto expuesto en el host (solo dev: DBeaver, etc.)

# ── Redis ─────────────────────────────────────────────────────────────────────
# Producción: usar nombre del servicio Docker ("redis")
REDIS_URL=redis://redis:6379/0
# Desarrollo nativo (Django en host, Redis en Docker Desktop):
# REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Si EMAIL_HOST no está definido, se usa el backend de consola (solo en DEBUG).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu@email.com
EMAIL_HOST_PASSWORD=tu-contraseña-de-app
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# ── Adjuntos en Nextcloud (WebDAV) ────────────────────────────────────────────
# Todos los adjuntos de tickets se guardan en Nextcloud vía WebDAV con un app-password.
# NEXTCLOUD_URL = URL base WebDAV de tu usuario (ojo: incluye /remote.php/dav/files/<usuario>)
# NEXTCLOUD_TOKEN = "app password" generado en Nextcloud → Ajustes → Seguridad → Dispositivos.
# NEXTCLOUD_URL=https://nube.tudominio.com/remote.php/dav/files/usuario
# NEXTCLOUD_USER=usuario
# NEXTCLOUD_TOKEN=xxxxx-xxxxx-xxxxx-xxxxx-xxxxx
# NEXTCLOUD_ROOT=SkyDesk-Tickets
# ATTACHMENT_MAX_SIZE=20971520   # 20 MB (en bytes)

# ── n8n (opcional) ────────────────────────────────────────────────────────────
# n8n se habilita definiendo N8N_DOMAIN. Se despliega en su propio subdominio.
# N8N_ENCRYPTION_KEY debe mantenerse constante — cambiarla invalida credenciales.
# N8N_ENCRYPTION_KEY=clave-larga-y-secreta
# N8N_DOMAIN=n8n.tudominio.com

# ── n8n-MCP (opcional, requiere n8n) ─────────────────────────────────────────
# Servidor MCP sobre HTTP para integrar n8n con Claude Code u otros clientes MCP.
# N8N_MCP_ENABLED=true
# N8N_API_KEY=tu-api-key-de-n8n         # Generado en n8n: Settings > API
# N8N_MCP_AUTH_TOKEN=token-secreto      # Token para autenticar clientes MCP

# ── Integración Django ↔ n8n (opcional) ──────────────────────────────────────
# Variables disponibles en Django settings para llamar a n8n desde tu código.
# N8N_URL=https://n8n.tudominio.com
# N8N_WEBHOOK_URL=https://n8n.tudominio.com/webhook/
